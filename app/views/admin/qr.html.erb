<!DOCTYPE html>
<html>
<head>
  <title>QR Code — Bucker Labs Demo</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { margin: 0; background: #0A0C10; display: flex; align-items: center; justify-content: center; min-height: 100vh; flex-direction: column; gap: 28px; font-family: 'Sora', system-ui, sans-serif; }
    .qr-wrap { background: #fff; padding: 24px; border-radius: 16px; display: inline-block; }
    .label { color: #F5A623; font-size: 13px; letter-spacing: .15em; text-transform: uppercase; font-family: 'IBM Plex Mono', monospace; font-weight: 500; }
    .url { color: rgba(255,255,255,.4); font-size: 11px; font-family: 'IBM Plex Mono', monospace; margin-top: 6px; }
  </style>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
</head>
<body>
  <div class="label">Scan to try it yourself</div>
  <div class="qr-wrap"><%= @svg.html_safe %></div>
  <div class="url"><%= ENV.fetch("DEMO_URL", "http://localhost:3001") %></div>
</body>
</html>
