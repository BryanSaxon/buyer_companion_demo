<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
      body { margin: 0; padding: 0; background: #F1F1EF; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; -webkit-font-smoothing: antialiased; }
      .wrapper { max-width: 560px; margin: 32px auto; background: #fff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,.08); }
      .header { background: #1A1A1A; padding: 24px 32px; }
      .header-label { font-size: 10px; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; color: #F5A623; margin-bottom: 4px; }
      .header-title { font-size: 20px; font-weight: 700; color: #fff; letter-spacing: -.01em; }
      .body { padding: 28px 32px; }
      .field-row { display: flex; justify-content: space-between; align-items: baseline; padding: 9px 0; border-bottom: 1px solid #F0F0EE; }
      .field-row:last-child { border-bottom: none; }
      .field-label { font-size: 10px; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: #9aa0ac; }
      .field-value { font-size: 13px; font-weight: 600; color: #1A1A1A; }
      .section-title { font-size: 10px; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: #F5A623; margin: 20px 0 8px; }
      .card { background: #F5F5F3; border-radius: 10px; padding: 14px 16px; margin-bottom: 12px; }
      .footer { padding: 16px 32px; background: #F5F5F3; text-align: center; font-size: 11px; color: #9aa0ac; }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <%= yield %>
      <div class="footer">Buyer Companion · <%= DemoData::COMMUNITY[:name] %></div>
    </div>
  </body>
</html>
