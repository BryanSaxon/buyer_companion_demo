<% rooms_complete      = session.rooms_complete_count %>
<% total_rooms        = DemoData::ROOMS.count %>
<% pct               = total_rooms > 0 ? (rooms_complete.to_f / total_rooms * 100).round : 0 %>
<% planning_done     = !session.welcome? && !session.room_planning? %>
<% styles_done       = session.designing? || session.summary_review? || session.complete? %>
<% selections_by_room = session.design_selections.to_a.group_by(&:room_key) %>
<% completed_rooms   = DemoData::ROOMS.select { |r| session.room_fully_designed?(r[:key]) } %>
<% selected_styles   = session.design_styles_array
                              .reject { |k| k == "not_sure" }
                              .filter_map { |k| DemoData::DESIGN_STYLES.find { |s| s[:key] == k } } %>
<% has_palette = selected_styles.any? || completed_rooms.any? %>

<%# Helper: look up swatch hex for a saved selection %>
<% swatch_for = lambda { |sel|
  DemoData.selections_for(sel.room_key)
          .find { |s| s[:type] == sel.selection_type }
          &.dig(:options)
          &.find { |o| o[:key] == sel.option_key }
          &.dig(:swatch) || "#E4E6EA"
} %>

<div class="build-layout">

  <!-- ==========================================
       LEFT COLUMN — home & family (narrow)
       ========================================== -->
  <div class="build-layout__left">

    <%# Mobile-only: journey strip + palette appear FIRST on mobile %>
    <div class="build-mobile-journey">
      <!-- Compact home identity strip (mobile only) -->
      <div class="build-mobile-homestrip">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px">
          <div style="min-width:0">
            <div style="font:700 15px/1.2 'Sora',system-ui;color:#1A1A1A;letter-spacing:-.01em"><%= DemoData::HOME[:floorplan] %></div>
            <div style="font:400 11px 'Sora',system-ui;color:#9aa0ac;margin-top:2px"><%= DemoData::HOME[:bedrooms] %>bd &middot; <%= DemoData::HOME[:bathrooms] %>ba &middot; <%= DemoData::HOME[:sqft] %> sq ft &middot; <%= DemoData::HOME[:community] %> &middot; Lot <%= DemoData::HOME[:lot] %></div>
          </div>
          <button onclick="window.openHomeDrawer()" aria-label="Home &amp; Community Details"
                  style="flex:none;width:28px;height:28px;border-radius:50%;background:#ECEEF1;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#6b7280;-webkit-tap-highlight-color:transparent;margin-top:1px">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          </button>
        </div>
      </div>

      <!-- Home & Community Details drawer (mobile) -->
      <div id="home-details-overlay"
           onclick="if(event.target===this)window.closeHomeDrawer()"
           style="display:none;position:fixed;inset:0;z-index:1000;background:rgba(0,0,0,.4);backdrop-filter:blur(2px);-webkit-backdrop-filter:blur(2px)">
        <div id="home-details-drawer"
             style="position:absolute;bottom:0;left:0;right:0;max-height:90dvh;background:#FAFBFC;border-radius:20px 20px 0 0;display:flex;flex-direction:column;transform:translateY(100%);transition:transform .3s cubic-bezier(.32,0,.15,1)">
          <!-- Drag handle + header -->
          <div style="padding:12px 20px 0;flex:none">
            <div style="width:36px;height:4px;border-radius:2px;background:#E5E7EB;margin:0 auto 14px"></div>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
              <div style="font:600 10px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.12em;text-transform:uppercase;color:#9aa0ac">Home &amp; Community</div>
              <button onclick="window.closeHomeDrawer()" aria-label="Close"
                      style="width:28px;height:28px;border-radius:50%;background:#ECEEF1;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#6b7280">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </button>
            </div>
          </div>
          <!-- Scrollable content -->
          <div style="overflow-y:auto;padding:0 16px 32px;-webkit-overflow-scrolling:touch">
            <!-- Your Home card -->
            <div style="background:#fff;border:1px solid #E5E7EB;border-radius:14px;padding:16px 18px;box-shadow:0 2px 10px rgba(0,0,0,.04);margin-bottom:12px">
              <div style="font:600 9.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.12em;text-transform:uppercase;color:#F5A623;margin-bottom:8px">Your Home</div>
              <div style="font:700 17px/1.2 'Sora',system-ui;color:#1A1A1A;letter-spacing:-.02em;margin-bottom:8px"><%= DemoData::HOME[:floorplan] %></div>
              <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:9px">
                <% [["Community", DemoData::HOME[:community]], ["Phase", DemoData::HOME[:phase]], ["Lot", DemoData::HOME[:lot]]].each do |label, val| %>
                  <div style="display:flex;flex-direction:column;gap:2px;padding:7px 11px;background:#FAFBFC;border:1px solid #E5E7EB;border-radius:8px">
                    <span style="font:500 8px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.09em;text-transform:uppercase;color:#9aa0ac"><%= label %></span>
                    <span style="font:600 12px 'Sora',system-ui;color:#1A1A1A"><%= val %></span>
                  </div>
                <% end %>
              </div>
              <div style="font:400 12px 'Sora',system-ui;color:#9aa0ac">
                <%= DemoData::HOME[:bedrooms] %> bed · <%= DemoData::HOME[:bathrooms] %> bath · Flex room · <%= DemoData::HOME[:sqft] %> sq ft
              </div>
            </div>
            <!-- Family card -->
            <div style="background:#fff;border:1px solid #E5E7EB;border-radius:14px;padding:14px 18px;box-shadow:0 2px 10px rgba(0,0,0,.04);margin-bottom:12px">
              <div style="font:600 9.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.12em;text-transform:uppercase;color:#F5A623;margin-bottom:10px">The <%= session.effective_family.first&.dig(:last_name) || "Harrison" %> Family</div>
              <div style="display:flex;gap:8px">
                <% session.effective_family.each do |person| %>
                  <div style="display:flex;flex-direction:column;align-items:center;gap:4px;flex:1">
                    <div style="width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,#F5A623,#C27D1B);color:#fff;display:flex;align-items:center;justify-content:center;font:700 14px 'Sora',system-ui">
                      <%= person[:name][0] %>
                    </div>
                    <div style="font:600 11.5px 'Sora',system-ui;color:#1A1A1A"><%= person[:name] %></div>
                    <div style="font:400 10px 'Sora',system-ui;color:#9aa0ac"><%= person[:role] %></div>
                  </div>
                <% end %>
              </div>
            </div>
            <!-- Community card -->
            <div style="background:#fff;border:1px solid #E5E7EB;border-radius:14px;padding:16px 18px;box-shadow:0 2px 10px rgba(0,0,0,.04)">
              <div style="font:600 9.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.12em;text-transform:uppercase;color:#F5A623;margin-bottom:6px">The Community</div>
              <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px">
                <%= image_tag "community/reeds-vale-logo.svg", style: "width:36px;height:36px;flex:none", alt: "Reeds Vale" %>
                <div style="font:700 15px/1.2 'Sora',system-ui;color:#1A1A1A;letter-spacing:-.01em"><%= DemoData::COMMUNITY[:name] %></div>
              </div>
              <div style="font:400 11.5px 'Sora',system-ui;color:#9aa0ac;margin-bottom:12px"><%= DemoData::COMMUNITY[:tagline] %></div>
              <div style="font:600 8.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.1em;text-transform:uppercase;color:#9aa0ac;margin-bottom:6px">Amenities</div>
              <div style="display:flex;flex-wrap:wrap;gap:5px;margin-bottom:12px">
                <% DemoData::COMMUNITY[:amenities].each do |amenity| %>
                  <span style="font:500 10.5px 'Sora',system-ui;color:#1A1A1A;background:#F4F5F7;border:1px solid #E5E7EB;border-radius:20px;padding:3px 9px"><%= amenity %></span>
                <% end %>
              </div>
              <div style="font:600 8.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.1em;text-transform:uppercase;color:#9aa0ac;margin-bottom:5px">HOA</div>
              <div style="font:500 11.5px 'Sora',system-ui;color:#1A1A1A;margin-bottom:2px"><%= DemoData::COMMUNITY[:hoa][:monthly_dues] %></div>
              <div style="font:400 10.5px 'Sora',system-ui;color:#9aa0ac;margin-bottom:12px;line-height:1.4"><%= DemoData::COMMUNITY[:hoa][:covers] %></div>
              <div style="font:600 8.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.1em;text-transform:uppercase;color:#9aa0ac;margin-bottom:6px">Schools · <%= DemoData::COMMUNITY[:schools][:district] %></div>
              <div style="display:flex;flex-direction:column;gap:4px;margin-bottom:12px">
                <% [[:elementary, "Elementary"], [:middle, "Middle"], [:high, "High School"]].each do |key, level| %>
                  <div style="display:flex;align-items:baseline;gap:6px">
                    <span style="font:600 8.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.06em;text-transform:uppercase;color:#9aa0ac;flex:none;width:64px"><%= level %></span>
                    <span style="font:500 11px 'Sora',system-ui;color:#1A1A1A"><%= DemoData::COMMUNITY[:schools][key] %></span>
                  </div>
                <% end %>
              </div>
              <div style="display:flex;align-items:center;gap:7px;padding-top:10px;border-top:1px solid #ECEEF1">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#9aa0ac" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <span style="font:500 11.5px 'Sora',system-ui;color:#1A1A1A">Sales Office</span>
                <span style="font:600 11.5px 'Sora',system-ui;color:#F5A623"><%= DemoData::COMMUNITY[:sales_phone] %></span>
              </div>
            </div>
          </div>
        </div>
      </div>
      <script>
        window.openHomeDrawer = function() {
          var overlay = document.getElementById('home-details-overlay');
          var drawer  = document.getElementById('home-details-drawer');
          overlay.style.display = 'block';
          requestAnimationFrame(function() {
            requestAnimationFrame(function() {
              drawer.style.transform = 'translateY(0)';
            });
          });
          document.body.style.overflow = 'hidden';
        };
        window.closeHomeDrawer = function() {
          var overlay = document.getElementById('home-details-overlay');
          var drawer  = document.getElementById('home-details-drawer');
          drawer.style.transform = 'translateY(100%)';
          setTimeout(function() {
            overlay.style.display = 'none';
            document.body.style.overflow = '';
          }, 300);
        };
      </script>
      <%= render "home/build_journey_strip",
            session: session,
            rooms_complete: rooms_complete,
            total_rooms: total_rooms,
            pct: pct,
            planning_done: planning_done,
            styles_done: styles_done,
            selections_by_room: selections_by_room,
            completed_rooms: completed_rooms,
            selected_styles: selected_styles,
            has_palette: has_palette,
            swatch_for: swatch_for %>
    </div>

    <%# Info cards: collapsible on mobile, always visible on desktop %>
    <button class="build-info-toggle" onclick="window.toggleBuildInfo(this)" aria-expanded="false">
      <span>Home &amp; Community Details</span>
      <svg class="build-info-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="transition:transform .2s;flex:none"><polyline points="6 9 12 15 18 9"/></svg>
    </button>
    <div class="build-info-cards">
      <div class="c-section" style="padding-top:32px;padding-bottom:32px;animation:scRise .6s ease both">

        <!-- Property card -->
        <div style="background:#fff;border:1px solid #E5E7EB;border-radius:14px;padding:16px 18px;box-shadow:0 2px 10px rgba(0,0,0,.04);margin-bottom:14px">
          <div style="font:600 9.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.12em;text-transform:uppercase;color:#F5A623;margin-bottom:8px">Your Home</div>
          <div style="font:700 17px/1.2 'Sora',system-ui;color:#1A1A1A;letter-spacing:-.02em;margin-bottom:8px"><%= DemoData::HOME[:floorplan] %></div>
          <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:9px">
            <% [["Community", DemoData::HOME[:community]], ["Phase", DemoData::HOME[:phase]], ["Lot", DemoData::HOME[:lot]]].each do |label, val| %>
              <div style="display:flex;flex-direction:column;gap:2px;padding:7px 11px;background:#FAFBFC;border:1px solid #E5E7EB;border-radius:8px">
                <span style="font:500 8px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.09em;text-transform:uppercase;color:#9aa0ac"><%= label %></span>
                <span style="font:600 12px 'Sora',system-ui;color:#1A1A1A"><%= val %></span>
              </div>
            <% end %>
          </div>
          <div style="font:400 12px 'Sora',system-ui;color:#9aa0ac">
            <%= DemoData::HOME[:bedrooms] %> bed · <%= DemoData::HOME[:bathrooms] %> bath · Flex room · <%= DemoData::HOME[:sqft] %> sq ft
          </div>
        </div>

        <!-- Family card -->
        <div style="background:#fff;border:1px solid #E5E7EB;border-radius:14px;padding:14px 18px;box-shadow:0 2px 10px rgba(0,0,0,.04)">
          <div style="font:600 9.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.12em;text-transform:uppercase;color:#F5A623;margin-bottom:10px">The Harrison Family</div>
          <div style="display:flex;gap:8px">
            <% session.effective_family.each do |person| %>
              <div style="display:flex;flex-direction:column;align-items:center;gap:4px;flex:1">
                <div style="width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,#F5A623,#C27D1B);color:#fff;display:flex;align-items:center;justify-content:center;font:700 14px 'Sora',system-ui">
                  <%= person[:name][0] %>
                </div>
                <div style="font:600 11.5px 'Sora',system-ui;color:#1A1A1A"><%= person[:name] %></div>
                <div style="font:400 10px 'Sora',system-ui;color:#9aa0ac"><%= person[:role] %></div>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Community card -->
        <div style="background:#fff;border:1px solid #E5E7EB;border-radius:14px;padding:16px 18px;box-shadow:0 2px 10px rgba(0,0,0,.04);margin-top:14px">
          <div style="font:600 9.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.12em;text-transform:uppercase;color:#F5A623;margin-bottom:6px">The Community</div>
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px">
            <%= image_tag "community/reeds-vale-logo.svg", style: "width:36px;height:36px;flex:none", alt: "Reeds Vale" %>
            <div style="font:700 15px/1.2 'Sora',system-ui;color:#1A1A1A;letter-spacing:-.01em"><%= DemoData::COMMUNITY[:name] %></div>
          </div>
          <div style="font:400 11.5px 'Sora',system-ui;color:#9aa0ac;margin-bottom:12px"><%= DemoData::COMMUNITY[:tagline] %></div>

          <!-- Amenities -->
          <div style="font:600 8.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.1em;text-transform:uppercase;color:#9aa0ac;margin-bottom:6px">Amenities</div>
          <div style="display:flex;flex-wrap:wrap;gap:5px;margin-bottom:12px">
            <% DemoData::COMMUNITY[:amenities].each do |amenity| %>
              <span style="font:500 10.5px 'Sora',system-ui;color:#1A1A1A;background:#F4F5F7;border:1px solid #E5E7EB;border-radius:20px;padding:3px 9px"><%= amenity %></span>
            <% end %>
          </div>

          <!-- HOA -->
          <div style="font:600 8.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.1em;text-transform:uppercase;color:#9aa0ac;margin-bottom:5px">HOA</div>
          <div style="font:500 11.5px 'Sora',system-ui;color:#1A1A1A;margin-bottom:2px"><%= DemoData::COMMUNITY[:hoa][:monthly_dues] %></div>
          <div style="font:400 10.5px 'Sora',system-ui;color:#9aa0ac;margin-bottom:12px;line-height:1.4"><%= DemoData::COMMUNITY[:hoa][:covers] %></div>

          <!-- Schools -->
          <div style="font:600 8.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.1em;text-transform:uppercase;color:#9aa0ac;margin-bottom:6px">Schools · <%= DemoData::COMMUNITY[:schools][:district] %></div>
          <div style="display:flex;flex-direction:column;gap:4px;margin-bottom:12px">
            <% [[:elementary, "Elementary"], [:middle, "Middle"], [:high, "High School"]].each do |key, level| %>
              <div style="display:flex;align-items:baseline;gap:6px">
                <span style="font:600 8.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.06em;text-transform:uppercase;color:#9aa0ac;flex:none;width:64px"><%= level %></span>
                <span style="font:500 11px 'Sora',system-ui;color:#1A1A1A"><%= DemoData::COMMUNITY[:schools][key] %></span>
              </div>
            <% end %>
          </div>

          <!-- Sales contact -->
          <div style="display:flex;align-items:center;gap:7px;padding-top:10px;border-top:1px solid #ECEEF1">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#9aa0ac" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span style="font:500 11.5px 'Sora',system-ui;color:#1A1A1A">Sales Office</span>
            <span style="font:600 11.5px 'Sora',system-ui;color:#F5A623"><%= DemoData::COMMUNITY[:sales_phone] %></span>
          </div>
        </div>

      </div>
    </div><!-- /build-info-cards -->

    <script>
      window.toggleBuildInfo = function(btn) {
        var cards = btn.nextElementSibling;
        var isOpen = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
        cards.style.display = isOpen ? 'none' : 'block';
        btn.querySelector('.build-info-chevron').style.transform = isOpen ? '' : 'rotate(180deg)';
      };
    </script>

  </div><!-- /build-layout__left -->


  <!-- ==========================================
       RIGHT COLUMN — journey strip + palette
       ========================================== -->
  <div class="build-layout__right">
    <div class="build-desktop-journey">
      <%= render "home/build_journey_strip",
            session: session,
            rooms_complete: rooms_complete,
            total_rooms: total_rooms,
            pct: pct,
            planning_done: planning_done,
            styles_done: styles_done,
            selections_by_room: selections_by_room,
            completed_rooms: completed_rooms,
            selected_styles: selected_styles,
            has_palette: has_palette,
            swatch_for: swatch_for %>
    </div>
  </div><!-- /build-layout__right -->

</div><!-- /build-layout -->
