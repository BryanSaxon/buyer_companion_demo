<% rooms_complete = session.rooms_complete_count %>
<% total_rooms = 8 %>
<% pct = total_rooms > 0 ? (rooms_complete.to_f / total_rooms * 100).round : 0 %>
<% planning_done = !session.welcome? && !session.room_planning? %>
<% styles_done   = session.designing? || session.summary_review? || session.complete? %>
<% selections_by_room = session.design_selections.to_a.group_by(&:room_key) %>

<div class="c-section" style="padding-top:32px;padding-bottom:8px;animation:scRise .6s ease both">
  <!-- Property card -->
  <div style="background:#fff;border:1px solid #E5E7EB;border-radius:14px;padding:16px 18px;box-shadow:0 2px 10px rgba(0,0,0,.04);margin-bottom:14px">
    <div style="font:600 9.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.12em;text-transform:uppercase;color:#F5A623;margin-bottom:8px">Your Home</div>
    <div style="font:700 17px/1.2 'Sora',system-ui;color:#1A1A1A;letter-spacing:-.02em;margin-bottom:6px">The Brookfield</div>
    <div style="display:flex;flex-wrap:wrap;gap:6px">
      <% [["Community", DemoData::HOME[:community]], ["Phase", DemoData::HOME[:phase]], ["Lot", DemoData::HOME[:lot]]].each do |label, val| %>
        <div style="display:flex;flex-direction:column;gap:2px;padding:7px 11px;background:#FAFAF8;border:1px solid #E5E7EB;border-radius:8px">
          <span style="font:500 8px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.09em;text-transform:uppercase;color:#9aa0ac"><%= label %></span>
          <span style="font:600 12px 'Sora',system-ui;color:#1A1A1A"><%= val %></span>
        </div>
      <% end %>
    </div>
    <div style="margin-top:9px;font:400 12px 'Sora',system-ui;color:#9aa0ac">
      <%= DemoData::HOME[:bedrooms] %> bed · <%= DemoData::HOME[:bathrooms] %> bath · Flex room · <%= DemoData::HOME[:sqft] %> sq ft
    </div>
  </div>

  <!-- Family card -->
  <div style="background:#fff;border:1px solid #E5E7EB;border-radius:14px;padding:14px 18px;box-shadow:0 2px 10px rgba(0,0,0,.04);margin-bottom:14px">
    <div style="font:600 9.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.12em;text-transform:uppercase;color:#F5A623;margin-bottom:10px">The Morgan Family</div>
    <div style="display:flex;gap:8px">
      <% DemoData::FAMILY.each do |person| %>
        <div style="display:flex;flex-direction:column;align-items:center;gap:4px;flex:1">
          <div style="width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,#F5A623,#C27D1B);color:#fff;display:flex;align-items:center;justify-content:center;font:700 14px 'Sora',system-ui">
            <%= person[:name][0] %>
          </div>
          <div style="font:600 11.5px 'Sora',system-ui;color:#1A1A1A"><%= person[:name] %></div>
          <div style="font:400 10px 'Sora',system-ui;color:#9aa0ac"><%= person[:role] %></div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Progress tracker -->
  <div style="background:#fff;border:1px solid #E5E7EB;border-radius:14px;padding:14px 18px;box-shadow:0 2px 10px rgba(0,0,0,.04)">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
      <div style="font:600 9.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.12em;text-transform:uppercase;color:#F5A623">Design Journey</div>
      <div style="font:600 10px 'IBM Plex Mono',ui-monospace,monospace;color:#9aa0ac"><%= rooms_complete %> of <%= total_rooms %> rooms</div>
    </div>
    <div style="height:4px;background:#E5E7EB;border-radius:2px;overflow:hidden;margin-bottom:14px">
      <div style="height:100%;width:<%= pct %>%;background:#F5A623;border-radius:2px;transition:width .4s ease"></div>
    </div>

    <!-- Phase indicators -->
    <% [
      { label: "Room Planning", done: planning_done, active: session.room_planning? },
      { label: "Design Styles", done: styles_done,   active: session.style_selection? },
    ].each do |phase| %>
      <div style="display:flex;align-items:center;gap:9px;padding:5px 0;border-bottom:1px solid #F5F4EF">
        <% if phase[:done] %>
          <div style="width:16px;height:16px;border-radius:50%;background:#22a06b;color:#fff;display:flex;align-items:center;justify-content:center;font-size:9px;flex:none">✓</div>
          <span style="font:400 12.5px 'Sora',system-ui;color:#9aa0ac;text-decoration:line-through"><%= phase[:label] %></span>
        <% elsif phase[:active] %>
          <div style="width:16px;height:16px;border-radius:50%;border:2px solid #F5A623;background:rgba(245,166,35,.1);display:flex;align-items:center;justify-content:center;flex:none">
            <div style="width:6px;height:6px;border-radius:50%;background:#F5A623"></div>
          </div>
          <span style="font:600 12.5px 'Sora',system-ui;color:#1A1A1A"><%= phase[:label] %></span>
        <% else %>
          <div style="width:16px;height:16px;border-radius:50%;border:1.5px solid #E5E7EB;flex:none"></div>
          <span style="font:400 12.5px 'Sora',system-ui;color:#b3b8c0"><%= phase[:label] %></span>
        <% end %>
      </div>
    <% end %>

    <!-- Room rows -->
    <% DemoData::ROOMS.each do |room| %>
      <% is_done   = session.room_fully_designed?(room[:key]) %>
      <% is_active = !session.complete? && session.designing? && session.current_room == room[:key] %>
      <% if is_done %>
        <div style="display:flex;align-items:center;gap:9px;padding:5px 0;cursor:pointer;user-select:none"
             data-action="click->companion#toggleRoomDrawer"
             data-room-key="<%= room[:key] %>">
          <div style="width:16px;height:16px;border-radius:50%;background:#22a06b;color:#fff;display:flex;align-items:center;justify-content:center;font-size:9px;flex:none">✓</div>
          <span style="font:400 12px 'Sora',system-ui;color:#9aa0ac;text-decoration:line-through"><%= room[:label] %></span>
          <svg id="chevron-<%= room[:key] %>" style="margin-left:auto;flex:none;transition:transform .15s;color:#c8ccd4" viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </div>
        <div id="room-drawer-<%= room[:key] %>" style="display:none;padding:4px 0 10px 25px">
          <% (selections_by_room[room[:key]] || []).each do |sel| %>
            <div style="display:flex;justify-content:space-between;align-items:baseline;gap:8px;padding:2px 0">
              <span style="font:500 9px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.08em;text-transform:uppercase;color:#b3b8c0;white-space:nowrap;flex:none"><%= sel.selection_type.humanize %></span>
              <span style="font:500 11.5px 'Sora',system-ui;color:<%= sel.pending? ? '#b3b8c0' : '#1A1A1A' %>;text-align:right"><%= sel.pending? ? '—' : sel.option_label %></span>
            </div>
          <% end %>
          <button style="margin-top:8px;font:600 11px 'Sora',system-ui;color:#F5A623;background:none;border:none;cursor:pointer;padding:0;display:flex;align-items:center;gap:3px"
                  data-action="click->companion#editRoomFromBrief"
                  data-room-key="<%= room[:key] %>">
            Edit in chat
            <svg viewBox="0 0 24 24" width="9" height="9" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      <% elsif is_active %>
        <div style="display:flex;align-items:center;gap:9px;padding:5px 0">
          <div style="width:16px;height:16px;border-radius:50%;border:2px solid #F5A623;background:rgba(245,166,35,.1);display:flex;align-items:center;justify-content:center;flex:none">
            <div style="width:6px;height:6px;border-radius:50%;background:#F5A623"></div>
          </div>
          <span style="font:600 12px 'Sora',system-ui;color:#1A1A1A"><%= room[:label] %></span>
        </div>
      <% else %>
        <div style="display:flex;align-items:center;gap:9px;padding:5px 0">
          <div style="width:16px;height:16px;border-radius:50%;border:1.5px solid #E5E7EB;flex:none"></div>
          <span style="font:400 12px 'Sora',system-ui;color:#b3b8c0"><%= room[:label] %></span>
        </div>
      <% end %>
    <% end %>
  </div>
</div>

<!-- Footer -->
<div class="c-section" style="padding-top:24px;padding-bottom:36px">
  <div style="display:flex;align-items:center;gap:9px">
    <div style="width:11px;height:11px;border-radius:3px;background:#F5A623"></div>
    <span style="font:700 11px 'Sora',system-ui;letter-spacing:.18em;color:#1A1A1A">BUCKER LABS</span>
    <span style="font:500 9px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.06em;text-transform:uppercase;color:#b3b8c0;margin-left:auto">No password · No location</span>
  </div>
</div>
