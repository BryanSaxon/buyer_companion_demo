<div data-build-tabs style="animation:scRise .65s ease both">

  <!-- ── Tab bar ───────────────────────────────────────────────── -->
  <div style="display:flex;position:sticky;top:0;z-index:5;background:rgba(247,247,246,.96);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);border-bottom:1px solid #E5E7EB">
    <button onclick="window.switchBuildTab(this,'design')" data-build-tab="design"
            style="flex:1;padding:12px 16px;border:none;border-bottom:2px solid #F5A623;background:none;cursor:pointer;font:600 11px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.1em;text-transform:uppercase;color:#F5A623;-webkit-tap-highlight-color:transparent">
      Design Journey
    </button>
    <button onclick="window.switchBuildTab(this,'progress')" data-build-tab="progress"
            style="flex:1;padding:12px 16px;border:none;border-bottom:2px solid transparent;background:none;cursor:pointer;font:600 11px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.1em;text-transform:uppercase;color:#9aa0ac;-webkit-tap-highlight-color:transparent">
      Build Progress
    </button>
    <button onclick="window.switchBuildTab(this,'documents')" data-build-tab="documents"
            style="flex:1;padding:12px 16px;border:none;border-bottom:2px solid transparent;background:none;cursor:pointer;font:600 11px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.1em;text-transform:uppercase;color:#9aa0ac;-webkit-tap-highlight-color:transparent">
      Documents
    </button>
  </div>

  <!-- ── Design Journey panel ─────────────────────────────────── -->
  <div data-build-panel="design" style="padding:28px 28px 48px;display:block">

    <!-- ── Your Home hero — elevation + floor plans ────────────── -->
    <div style="margin-bottom:28px">
      <div style="font:600 9.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.12em;text-transform:uppercase;color:#F5A623;margin-bottom:4px">Your Home</div>
      <div style="font:700 20px/1.2 'Sora',system-ui;color:#1A1A1A;letter-spacing:-.02em;margin-bottom:4px"><%= DemoData::HOME[:floorplan] %></div>
      <div style="font:400 12px 'Sora',system-ui;color:#9aa0ac;margin-bottom:14px"><%= DemoData::HOME[:bedrooms] %> bed &middot; <%= DemoData::HOME[:bathrooms] %> bath &middot; <%= DemoData::HOME[:sqft] %> sq ft &middot; Home Site <%= DemoData::HOME[:lot].gsub("Home Site ","") %></div>

      <%# Front elevation %>
      <%= image_tag "home/elevation.webp",
            style: "width:100%;border-radius:14px;object-fit:cover;aspect-ratio:16/9;display:block;box-shadow:0 4px 20px rgba(0,0,0,.12);margin-bottom:12px",
            loading: "lazy",
            alt: "#{DemoData::HOME[:floorplan]} front elevation" %>

      <%# Floor plans — side by side %>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <div style="background:#fff;border:1px solid #E5E7EB;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.04)">
          <div style="font:600 8.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.1em;text-transform:uppercase;color:#9aa0ac;padding:8px 12px 4px">Main Floor</div>
          <%= image_tag "home/floorplan-main.webp",
                style: "width:100%;display:block;background:#fafafa",
                loading: "lazy",
                alt: "#{DemoData::HOME[:floorplan]} main floor plan" %>
        </div>
        <div style="background:#fff;border:1px solid #E5E7EB;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.04)">
          <div style="font:600 8.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.1em;text-transform:uppercase;color:#9aa0ac;padding:8px 12px 4px">Upper Floor</div>
          <%= image_tag "home/floorplan-upper.webp",
                style: "width:100%;display:block;background:#fafafa",
                loading: "lazy",
                alt: "#{DemoData::HOME[:floorplan]} upper floor plan" %>
        </div>
      </div>
    </div>

    <div style="height:1px;background:#E5E7EB;margin-bottom:28px"></div>

    <!-- ── Journey progress heading ───────────────────────────── -->
    <div style="margin-bottom:18px">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
        <div style="font:600 9.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.12em;text-transform:uppercase;color:#F5A623">Design Journey</div>
        <div style="font:600 10px 'IBM Plex Mono',ui-monospace,monospace;color:#9aa0ac"><%= rooms_complete %> of <%= total_rooms %> rooms</div>
      </div>
      <div style="height:3px;background:#E5E7EB;border-radius:2px;overflow:hidden">
        <div style="height:100%;width:<%= pct %>%;background:#22c55e;border-radius:2px;transition:width .5s ease"></div>
      </div>
    </div>

    <!-- ── Phase chips ─────────────────────────────────────────── -->
    <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:10px">
      <% [
        { label: "Room Planning", done: planning_done, active: session.room_planning? },
        { label: "Design Styles", done: styles_done,   active: session.style_selection? },
      ].each do |phase| %>
        <% if phase[:done] %>
          <div style="display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:999px;background:#dcfce7;border:1px solid #bbf7d0">
            <svg viewBox="0 0 12 12" width="9" height="9" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg>
            <span style="font:600 10.5px 'Sora',system-ui;color:#166534"><%= phase[:label] %></span>
          </div>
        <% elsif phase[:active] %>
          <div style="display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:999px;background:rgba(245,166,35,.1);border:1.5px solid #F5A623">
            <div style="width:6px;height:6px;border-radius:50%;background:#F5A623;animation:tabDotPulse 1.4s ease-in-out infinite"></div>
            <span style="font:600 10.5px 'Sora',system-ui;color:#C27D1B"><%= phase[:label] %></span>
          </div>
        <% else %>
          <div style="display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:999px;background:#F4F5F7;border:1.5px dashed #D1D5DB">
            <span style="font:500 10.5px 'Sora',system-ui;color:#c8ccd4"><%= phase[:label] %></span>
          </div>
        <% end %>
      <% end %>
    </div>

    <!-- ── Room chips (clickable → Concierge) ──────────────────── -->
    <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:28px">
      <% DemoData::ROOMS.each do |room| %>
        <% is_done   = session.room_fully_designed?(room[:key]) %>
        <% is_active = !session.complete? && session.designing? && session.current_room == room[:key] %>

        <% if is_done %>
          <button style="display:inline-flex;align-items:center;gap:5px;padding:5px 11px;border-radius:999px;background:#dcfce7;border:1px solid #bbf7d0;cursor:pointer;transition:filter .12s"
                  onmouseover="this.style.filter='brightness(.96)'" onmouseout="this.style.filter=''"
                  data-action="click->concierge#editRoomFromBrief"
                  data-room-key="<%= room[:key] %>">
            <svg viewBox="0 0 12 12" width="9" height="9" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg>
            <span style="font:600 10.5px 'Sora',system-ui;color:#166534"><%= room[:label] %></span>
          </button>
        <% elsif is_active %>
          <button style="display:inline-flex;align-items:center;gap:5px;padding:5px 11px;border-radius:999px;background:rgba(245,166,35,.1);border:1.5px solid #F5A623;cursor:pointer;transition:filter .12s"
                  onmouseover="this.style.filter='brightness(.96)'" onmouseout="this.style.filter=''"
                  data-action="click->concierge#showChat">
            <div style="width:6px;height:6px;border-radius:50%;background:#F5A623;animation:tabDotPulse 1.4s ease-in-out infinite;flex:none"></div>
            <span style="font:600 10.5px 'Sora',system-ui;color:#C27D1B"><%= room[:label] %></span>
          </button>
        <% else %>
          <button style="display:inline-flex;align-items:center;padding:5px 11px;border-radius:999px;background:#F4F5F7;border:1.5px dashed #D1D5DB;cursor:pointer;transition:filter .12s"
                  onmouseover="this.style.filter='brightness(.96)'" onmouseout="this.style.filter=''"
                  data-action="click->concierge#showChat">
            <span style="font:500 10.5px 'Sora',system-ui;color:#c8ccd4"><%= room[:label] %></span>
          </button>
        <% end %>
      <% end %>
    </div>

    <!-- ── Divider ──────────────────────────────────────────────── -->
    <div style="height:1px;background:#E5E7EB;margin-bottom:28px"></div>

    <!-- ── Your Palette heading ─────────────────────────────────── -->
    <div style="margin-bottom:24px">
      <div style="font:600 9.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.12em;text-transform:uppercase;color:#F5A623;margin-bottom:4px">Your Palette</div>
      <div style="font:700 20px/1.2 'Sora',system-ui;color:#1A1A1A;letter-spacing:-.02em">Design Story</div>
      <div style="font:400 12.5px 'Sora',system-ui;color:#9aa0ac;margin-top:4px">Your selections build here in real time</div>
    </div>

    <% if !has_palette %>
      <!-- Empty state -->
      <div style="border:1.5px dashed #E5E7EB;border-radius:16px;padding:40px 24px;text-align:center;background:#fff">
        <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="#D1D5DB" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto 12px;display:block"><rect x="3" y="3" width="18" height="18" rx="4"/><path d="M3 9h18M9 21V9"/></svg>
        <div style="font:600 13px 'Sora',system-ui;color:#9aa0ac;margin-bottom:6px">Palette in progress</div>
        <div style="font:400 12px 'Sora',system-ui;color:#b3b8c0;line-height:1.5">Start chatting with Aria — your design choices will appear here as a live mood board.</div>
      </div>
    <% else %>

      <%# ── Room palettes ──────────────────────────────────────── %>
      <% image_for = lambda { |sel|
        DemoData.selections_for(sel.room_key)
                .find { |s| s[:type] == sel.selection_type }
                &.dig(:options)
                &.find { |o| o[:key] == sel.option_key }
                &.dig(:image)
      } %>
      <% preloaded_renders = session.design_renders.to_a %>
      <% if completed_rooms.any? %>
        <div style="margin-bottom:8px">
          <div style="font:600 9px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.12em;text-transform:uppercase;color:#9aa0ac;margin-bottom:10px;display:flex;align-items:center;gap:8px">
            <span>Room Selections</span>
            <div style="flex:1;height:1px;background:#E5E7EB"></div>
          </div>
          <div style="display:flex;flex-direction:column;gap:12px">
            <% completed_rooms.each do |room| %>
              <% room_sels = (selections_by_room[room[:key]] || []).sort_by(&:created_at) %>
              <% room_render = preloaded_renders.find { |dr| dr.room_key == room[:key] && dr.status == "complete" } %>
              <% if room_render&.image&.attached? %>
                <%# Two-column on desktop, image-top stacked on mobile %>
                <div class="room-render-card">
                  <%# Left on desktop / bottom on mobile: selections card %>
                  <div class="room-render-card__sels" style="background:#fff;border:1px solid #E5E7EB;border-radius:14px;padding:14px 16px;box-shadow:0 2px 8px rgba(0,0,0,.04)">
                    <div style="font:600 10px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.1em;text-transform:uppercase;color:#1A1A1A;margin-bottom:12px"><%= room[:label] %></div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
                      <% room_sels.each do |sel| %>
                        <% sel_image = sel.pending? ? nil : image_for.call(sel) %>
                        <div style="display:flex;flex-direction:column;gap:7px">
                          <% if sel.pending? %>
                            <div style="width:100%;aspect-ratio:3/2;border-radius:8px;border:1.5px dashed #D1D5DB;background:#FAFBFC;display:flex;align-items:center;justify-content:center;color:#c8ccd4;font:500 14px 'Sora',system-ui">—</div>
                          <% elsif sel_image %>
                            <%= image_tag sel_image, style: "width:100%;aspect-ratio:3/2;object-fit:cover;border-radius:8px;border:1px solid rgba(0,0,0,.06);box-shadow:0 1px 4px rgba(0,0,0,.08);display:block", loading: "lazy", alt: "" %>
                          <% else %>
                            <div style="width:100%;aspect-ratio:3/2;border-radius:8px;background:<%= swatch_for.call(sel) %>;border:1px solid rgba(0,0,0,.06);box-shadow:0 1px 4px rgba(0,0,0,.08)"></div>
                          <% end %>
                          <div>
                            <div style="font:500 8px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.06em;text-transform:uppercase;color:#9aa0ac;margin-bottom:2px"><%= sel.selection_type.humanize %></div>
                            <div style="font:600 11px 'Sora',system-ui;color:<%= sel.pending? ? '#c8ccd4' : '#1A1A1A' %>;line-height:1.3"><%= sel.pending? ? "TBD" : sel.option_label %></div>
                          </div>
                        </div>
                      <% end %>
                    </div>
                  </div>
                  <%# Right on desktop / top on mobile: AI render %>
                  <div class="room-render-card__render" style="display:flex;flex-direction:column">
                    <div style="font:500 8px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.09em;text-transform:uppercase;color:#F5A623;margin-bottom:6px">✦ AI Rendering</div>
                    <%= image_tag url_for(room_render.image),
                          style: "flex:1;width:100%;min-height:0;object-fit:cover;border-radius:12px;display:block;box-shadow:0 4px 16px rgba(0,0,0,.12)",
                          loading: "lazy",
                          alt: "#{room[:label]} AI rendering" %>
                  </div>
                </div>
              <% else %>
                <%# Single card — no render yet %>
                <div style="background:#fff;border:1px solid #E5E7EB;border-radius:14px;padding:13px 15px;box-shadow:0 2px 8px rgba(0,0,0,.04)">
                  <div style="font:600 10px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.1em;text-transform:uppercase;color:#1A1A1A;margin-bottom:11px"><%= room[:label] %></div>
                  <div style="display:flex;flex-wrap:wrap;gap:14px">
                    <% room_sels.each do |sel| %>
                      <% sel_image = sel.pending? ? nil : image_for.call(sel) %>
                      <div style="display:flex;flex-direction:column;align-items:center;gap:5px;min-width:50px">
                        <% if sel.pending? %>
                          <div style="width:42px;height:42px;border-radius:8px;border:1.5px dashed #D1D5DB;background:#FAFBFC;display:flex;align-items:center;justify-content:center;color:#c8ccd4;font:500 14px 'Sora',system-ui">—</div>
                        <% elsif sel_image %>
                          <%= image_tag sel_image, style: "width:42px;height:42px;object-fit:cover;border-radius:8px;border:1px solid rgba(0,0,0,.06);box-shadow:0 2px 6px rgba(0,0,0,.1);display:block", loading: "lazy", alt: "" %>
                        <% else %>
                          <div style="width:42px;height:42px;border-radius:50%;background:<%= swatch_for.call(sel) %>;border:1px solid rgba(0,0,0,.06);box-shadow:0 2px 6px rgba(0,0,0,.1)"></div>
                        <% end %>
                        <div style="font:500 8px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.06em;text-transform:uppercase;color:#9aa0ac;text-align:center;line-height:1.3"><%= sel.selection_type.humanize %></div>
                        <% unless sel.pending? %>
                          <div style="font:500 10px 'Sora',system-ui;color:#1A1A1A;text-align:center;line-height:1.3;max-width:70px"><%= sel.option_label.split(" - ").last || sel.option_label %></div>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

    <% end %>

  </div><!-- /data-build-panel="design" -->

  <!-- ── Build Progress panel ─────────────────────────────────── -->
  <div data-build-panel="progress" style="padding:28px 28px 48px;display:none">

    <div style="margin-bottom:24px">
      <div style="font:600 9.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.12em;text-transform:uppercase;color:#F5A623;margin-bottom:4px">Build Progress</div>
      <div style="font:700 20px/1.2 'Sora',system-ui;color:#1A1A1A;letter-spacing:-.02em">Your Home, Taking Shape</div>
      <div style="font:400 12.5px 'Sora',system-ui;color:#9aa0ac;margin-top:4px">Live updates from your lot at <%= DemoData::COMMUNITY[:name] %></div>
    </div>

    <div style="display:flex;flex-direction:column;gap:20px">
      <% DemoData::BUILD_STAGES.each do |stage| %>
        <div style="background:#fff;border:1px solid #E5E7EB;border-radius:14px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.04)">

          <!-- Stage header -->
          <div style="display:flex;align-items:center;justify-content:space-between;padding:13px 16px;border-bottom:1px solid #ECEEF1">
            <div style="display:flex;align-items:center;gap:8px">
              <span style="font:700 10px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.1em;text-transform:uppercase;color:#9aa0ac">Stage <%= stage[:stage] %></span>
              <span style="font:600 12.5px 'Sora',system-ui;color:#1A1A1A"><%= stage[:label] %></span>
            </div>
            <% if stage[:status] == :complete %>
              <div style="display:inline-flex;align-items:center;gap:4px;padding:3px 9px;border-radius:999px;background:#dcfce7;border:1px solid #bbf7d0">
                <svg viewBox="0 0 12 12" width="8" height="8" fill="none" stroke="#16a34a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg>
                <span style="font:600 9.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.07em;text-transform:uppercase;color:#166534">Complete</span>
              </div>
            <% elsif stage[:status] == :in_progress %>
              <div style="display:inline-flex;align-items:center;gap:5px;padding:3px 9px;border-radius:999px;background:rgba(245,166,35,.1);border:1.5px solid #F5A623">
                <div style="width:5px;height:5px;border-radius:50%;background:#F5A623;animation:tabDotPulse 1.4s ease-in-out infinite;flex:none"></div>
                <span style="font:600 9.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.07em;text-transform:uppercase;color:#C27D1B">In Progress</span>
              </div>
            <% else %>
              <div style="display:inline-flex;align-items:center;padding:3px 9px;border-radius:999px;background:#F4F5F7;border:1.5px dashed #D1D5DB">
                <span style="font:600 9.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.07em;text-transform:uppercase;color:#c8ccd4">Upcoming</span>
              </div>
            <% end %>
          </div>

          <!-- Photo grid or placeholder depending on stage status -->
          <% if stage[:status] == :upcoming %>
            <div style="padding:32px 24px;text-align:center;background:#FAFBFC">
              <div style="width:44px;height:44px;border-radius:12px;background:#F0F1F3;border:1.5px dashed #D1D5DB;display:flex;align-items:center;justify-content:center;margin:0 auto 12px">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c8ccd4" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
                  <circle cx="12" cy="13" r="4"/>
                </svg>
              </div>
              <div style="font:600 12px 'Sora',system-ui;color:#9aa0ac;margin-bottom:4px">Photos Coming Soon</div>
              <div style="font:400 11px 'Sora',system-ui;color:#b3b8c0;line-height:1.5">Progress photos will appear here once this phase begins.</div>
            </div>
          <% else %>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:2px;background:#E5E7EB">
              <% stage[:photos].first(4).each do |photo| %>
                <%= image_tag "progress/stage-#{stage[:stage]}/#{photo}",
                      style: "width:100%;aspect-ratio:4/3;object-fit:cover;display:block",
                      loading: "lazy",
                      alt: "#{stage[:label]} progress photo" %>
              <% end %>
            </div>
          <% end %>

        </div>
      <% end %>
    </div>

  </div><!-- /data-build-panel="progress" -->

  <!-- ── Documents panel ──────────────────────────────────────── -->
  <div data-build-panel="documents" style="padding:28px 28px 48px;display:none">

    <div style="margin-bottom:24px">
      <div style="font:600 9.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.12em;text-transform:uppercase;color:#F5A623;margin-bottom:4px">Documents</div>
      <div style="font:700 20px/1.2 'Sora',system-ui;color:#1A1A1A;letter-spacing:-.02em">Your Home Documents</div>
      <div style="font:400 12.5px 'Sora',system-ui;color:#9aa0ac;margin-top:4px">Contracts, warranties, and important paperwork</div>
    </div>

    <% if DemoData::DOCUMENTS.any? %>
      <div style="display:flex;flex-direction:column;gap:10px">
        <% DemoData::DOCUMENTS.each do |doc| %>
          <div style="background:#fff;border:1px solid #E5E7EB;border-radius:14px;padding:14px 16px;box-shadow:0 2px 8px rgba(0,0,0,.04);display:flex;align-items:center;gap:14px">
            <!-- PDF icon -->
            <div style="width:40px;height:40px;border-radius:10px;background:#FEF2F2;border:1px solid #FECACA;display:flex;align-items:center;justify-content:center;flex:none">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
                <line x1="9" y1="15" x2="15" y2="15"/><line x1="9" y1="11" x2="11" y2="11"/>
              </svg>
            </div>
            <!-- Doc info -->
            <div style="flex:1;min-width:0">
              <div style="font:600 13px 'Sora',system-ui;color:#1A1A1A;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= doc[:name] %></div>
              <div style="font:400 10.5px 'Sora',system-ui;color:#9aa0ac;margin-top:2px"><%= doc[:category] %><% if doc[:size].present? %> &middot; <%= doc[:size] %><% end %></div>
            </div>
            <!-- Actions -->
            <div style="display:flex;gap:8px;flex:none">
              <a href="<%= "/documents/#{doc[:file]}" %>" target="_blank" rel="noopener"
                 style="display:inline-flex;align-items:center;gap:5px;padding:6px 12px;border-radius:8px;background:#F4F5F7;border:1px solid #E5E7EB;font:600 10px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.07em;text-transform:uppercase;color:#1A1A1A;text-decoration:none;transition:background .12s"
                 onmouseover="this.style.background='#EAEAE7'" onmouseout="this.style.background='#F4F5F7'">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                View
              </a>
              <a href="<%= "/documents/#{doc[:file]}" %>" download="<%= doc[:name] %>"
                 style="display:inline-flex;align-items:center;gap:5px;padding:6px 12px;border-radius:8px;background:#F5A623;border:none;font:600 10px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.07em;text-transform:uppercase;color:#1A1A1A;text-decoration:none;transition:filter .12s"
                 onmouseover="this.style.filter='brightness(1.05)'" onmouseout="this.style.filter=''">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Download
              </a>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div style="text-align:center;padding:48px 24px">
        <div style="width:52px;height:52px;border-radius:14px;background:#F4F5F7;border:1.5px dashed #D1D5DB;display:flex;align-items:center;justify-content:center;margin:0 auto 14px">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c8ccd4" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        </div>
        <div style="font:600 13px 'Sora',system-ui;color:#1A1A1A;margin-bottom:4px">No documents yet</div>
        <div style="font:400 12px 'Sora',system-ui;color:#9aa0ac">Your contracts and important paperwork will appear here.</div>
      </div>
    <% end %>

  </div><!-- /data-build-panel="documents" -->

  <script>
    window.switchBuildTab = function(btn, tab) {
      var root = btn.closest('[data-build-tabs]');
      root.querySelectorAll('[data-build-tab]').forEach(function(b) {
        var on = b.dataset.buildTab === tab;
        b.style.color             = on ? '#F5A623' : '#9aa0ac';
        b.style.borderBottomColor = on ? '#F5A623' : 'transparent';
      });
      root.querySelectorAll('[data-build-panel]').forEach(function(p) {
        p.style.display = p.dataset.buildPanel === tab ? 'block' : 'none';
      });
    };
  </script>

</div><!-- /data-build-tabs -->
