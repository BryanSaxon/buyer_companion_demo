<% approved = @lead.approved_render %>
<% org_name = @lead.org_name %>
<% org_initials = @lead.org_initials %>
<% first_name = @lead.first_name_display %>

<div class="companion-outer">
  <div class="companion-card"
       data-controller="companion"
       data-companion-approve-url-value="<%= lead_approval_path(@lead) %>"
       data-companion-messages-url-value="<%= lead_messages_path(@lead) %>"
       data-companion-org-name-value="<%= org_name %>"
       data-companion-first-name-value="<%= first_name %>">

    <!-- ============ STICKY BRAND BAR ============ -->
    <div class="brand-bar">
      <div style="width:38px;height:38px;border-radius:12px;background:#F5A623;color:#1A1A2E;display:flex;align-items:center;justify-content:center;font:700 14px 'Sora',system-ui;flex:none"><%= org_initials %></div>
      <div style="line-height:1.2;min-width:0">
        <div style="font:600 14px 'Sora',system-ui;color:#1A1A1A;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= org_name %></div>
        <div style="font:500 9px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.13em;text-transform:uppercase;color:#9aa0ac">Your home companion</div>
      </div>
      <div style="margin-left:auto;text-align:right;font:500 8px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.13em;text-transform:uppercase;color:#b3b8c0;line-height:1.5;flex:none">Powered by<br>Bucker Labs</div>
    </div>

    <!-- ============ MOBILE TAB BAR (hidden on desktop) ============ -->
    <div class="mobile-tab-bar">
      <button class="mobile-tab active" data-action="click->companion#showHome" data-companion-target="homeTab">
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11.2 12 4l9 7.2"/><path d="M5.5 9.6V19h13V9.6"/><path d="M10 19v-5h4v5"/></svg>
        My home
      </button>
      <button class="mobile-tab" data-action="click->companion#showChat" data-companion-target="chatTab">
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        Companion
        <span class="tab-dot" data-companion-target="tabDot"></span>
      </button>
    </div>

    <!-- ============ RESPONSIVE CONTENT GRID ============ -->
    <div class="companion-grid" data-companion-target="grid">

      <!-- ====== LEFT / MAIN ====== -->
      <div class="companion-main">

        <!-- GREETING -->
        <div class="c-section" style="padding-top:38px;padding-bottom:4px;animation:scRise .6s ease both">
          <div style="display:flex;align-items:center;gap:8px">
            <span style="width:6px;height:6px;border-radius:50%;background:#F5A623"></span>
            <span style="font:600 10.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.15em;text-transform:uppercase;color:#F5A623">It knows you</span>
          </div>

          <!-- Desktop: heading+desc left / chips right. Mobile: stacked -->
          <div class="c-greeting-layout">
            <div>
              <h1 class="greeting-headline" style="margin:14px 0 0;font:700 43px/1.04 'Sora',system-ui;color:#1A1A1A;letter-spacing:-.03em">Hello, <%= first_name %>.</h1>
              <p style="margin:14px 0 0;font:400 16.5px/1.5 'Sora',system-ui;color:#6B7280">Here's the home we've been building together — with every selection you've made already in place.</p>

              <!-- Fact chips: shown inline on mobile; hidden on desktop (appear in right col) -->
              <div class="c-fact-chips-mobile" style="display:flex;flex-wrap:wrap;gap:8px;margin-top:20px">
                <div style="display:flex;flex-direction:column;gap:3px;padding:11px 15px;background:#fff;border:1px solid #E5E7EB;border-radius:12px;box-shadow:0 2px 12px rgba(0,0,0,.04)">
                  <span style="font:500 8.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.1em;text-transform:uppercase;color:#9aa0ac">Plan</span>
                  <span style="font:600 13.5px 'Sora',system-ui;color:#1A1A1A;letter-spacing:-.01em">The Brookfield</span>
                </div>
                <div style="display:flex;flex-direction:column;gap:3px;padding:11px 15px;background:#fff;border:1px solid #E5E7EB;border-radius:12px;box-shadow:0 2px 12px rgba(0,0,0,.04)">
                  <span style="font:500 8.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.1em;text-transform:uppercase;color:#9aa0ac">Lot</span>
                  <span style="font:600 13.5px 'Sora',system-ui;color:#1A1A1A;letter-spacing:-.01em">Lot 24</span>
                </div>
                <div style="display:flex;flex-direction:column;gap:3px;padding:11px 15px;background:#fff;border:1px solid #E5E7EB;border-radius:12px;box-shadow:0 2px 12px rgba(0,0,0,.04)">
                  <span style="font:500 8.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.1em;text-transform:uppercase;color:#9aa0ac">Stage</span>
                  <span style="font:600 13.5px 'Sora',system-ui;color:#1A1A1A;letter-spacing:-.01em">Final review</span>
                </div>
              </div>
            </div>

            <!-- Fact chips column: desktop-only right column -->
            <div class="c-greeting-chips-col">
              <div style="display:flex;flex-direction:column;gap:3px;padding:12px 16px;background:#fff;border:1px solid #E5E7EB;border-radius:12px;box-shadow:0 2px 12px rgba(0,0,0,.04)">
                <span style="font:500 8.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.1em;text-transform:uppercase;color:#9aa0ac">Plan</span>
                <span style="font:600 14px 'Sora',system-ui;color:#1A1A1A;letter-spacing:-.01em">The Brookfield</span>
              </div>
              <div style="display:flex;flex-direction:column;gap:3px;padding:12px 16px;background:#fff;border:1px solid #E5E7EB;border-radius:12px;box-shadow:0 2px 12px rgba(0,0,0,.04)">
                <span style="font:500 8.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.1em;text-transform:uppercase;color:#9aa0ac">Lot</span>
                <span style="font:600 14px 'Sora',system-ui;color:#1A1A1A;letter-spacing:-.01em">Lot 24</span>
              </div>
              <div style="display:flex;flex-direction:column;gap:3px;padding:12px 16px;background:#fff;border:1px solid #E5E7EB;border-radius:12px;box-shadow:0 2px 12px rgba(0,0,0,.04)">
                <span style="font:500 8.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.1em;text-transform:uppercase;color:#9aa0ac">Stage</span>
                <span style="font:600 14px 'Sora',system-ui;color:#1A1A1A;letter-spacing:-.01em">Final review</span>
              </div>
            </div>
          </div>
        </div>

        <!-- KITCHEN RENDER -->
        <div class="c-section" style="padding-top:34px;padding-bottom:4px;animation:scRise .7s ease both">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:14px">
            <span style="width:6px;height:6px;border-radius:50%;background:#F5A623"></span>
            <span style="font:600 10.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.15em;text-transform:uppercase;color:#F5A623">Your kitchen — the render's back</span>
          </div>

          <div class="c-render-box" style="position:relative;aspect-ratio:4/3;width:100%;border-radius:16px;overflow:hidden;border:1px solid #E5E7EB;background:#F1F3F8;box-shadow:0 2px 12px rgba(0,0,0,.06)">
            <% if File.exist?(Rails.root.join("app/assets/images/kitchen-render.jpg")) || File.exist?(Rails.root.join("app/assets/images/kitchen-render.png")) %>
              <%= image_tag "kitchen-render", style: "display:block;width:100%;height:100%;object-fit:cover;" %>
            <% else %>
              <div style="width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px">
                <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="#b3b8c0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="18" height="18" rx="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <path d="m21 15-5-5L5 21"/>
                </svg>
                <span style="font:500 11px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.08em;text-transform:uppercase;color:#b3b8c0">Kitchen render</span>
                <span style="font:400 11px 'Sora',system-ui;color:#9aa0ac;text-align:center;max-width:180px">Add kitchen-render.jpg to app/assets/images/</span>
              </div>
            <% end %>
          </div>

          <div style="display:flex;align-items:center;gap:7px;margin-top:10px">
            <div style="width:5px;height:5px;border-radius:50%;background:#22a06b"></div>
            <span style="font:500 10px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.05em;text-transform:uppercase;color:#9aa0ac">Rendered from your live selections &middot; bundled offline</span>
          </div>

          <p style="margin:18px 0 0;font:400 15.5px/1.55 'Sora',system-ui;color:#3f3f3f">We've got the render back on your kitchen, with all your selections. Take a look — let us know if you approve, or ask me anything about it.</p>

          <!-- Selection pills: wrapping on mobile, 2-col grid on desktop -->
          <div class="c-selections" style="display:flex;flex-wrap:wrap;gap:7px;margin-top:16px">
            <% [["Cabinets", "Alpine White shaker"], ["Island", "Hale Navy"], ["Counters", "Calacatta Gold quartz"], ["Backsplash", "Zellige, gloss white"], ["Hardware", "Matte black pulls"], ["Floors", "Natural white oak"]].each do |label, value| %>
              <div style="display:inline-flex;align-items:center;gap:7px;padding:7px 12px;background:#fff;border:1px solid #E5E7EB;border-radius:999px">
                <span style="font:500 8.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.08em;text-transform:uppercase;color:#F5A623"><%= label %></span>
                <span style="font:600 12.5px 'Sora',system-ui;color:#1A1A1A;letter-spacing:-.01em"><%= value %></span>
              </div>
            <% end %>
          </div>

          <!-- Approve / approved state -->
          <div data-companion-target="approveRow" style="display:<%= approved ? 'none' : 'flex' %>;gap:10px;margin-top:20px">
            <button data-action="click->companion#approve"
              style="flex:1;padding:14px;border:none;border-radius:999px;background:#F5A623;color:#0A0C10;font:600 14.5px 'Sora',system-ui;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:filter .15s"
              onmouseover="this.style.filter='brightness(1.05)'" onmouseout="this.style.filter=''">
              <span style="font-size:15px">&#10003;</span> Approve the render
            </button>
            <button data-action="click->companion#askAboutKitchen"
              style="flex:none;padding:14px 18px;border:1px solid #E5E7EB;border-radius:999px;background:#fff;color:#1A1A1A;font:600 14.5px 'Sora',system-ui;cursor:pointer;transition:border-color .15s,color .15s"
              onmouseover="this.style.borderColor='#F5A623';this.style.color='#C27D1B'" onmouseout="this.style.borderColor='#E5E7EB';this.style.color='#1A1A1A'">
              Ask a question
            </button>
          </div>

          <div data-companion-target="approvedPanel" style="display:<%= approved ? 'flex' : 'none' %>;align-items:center;gap:11px;margin-top:20px;padding:14px 16px;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:12px">
            <div style="width:30px;height:30px;border-radius:50%;background:#22a06b;color:#fff;display:flex;align-items:center;justify-content:center;font-size:15px;flex:none">&#10003;</div>
            <div style="line-height:1.3">
              <div style="font:600 13.5px 'Sora',system-ui;color:#15803d">Approved &mdash; sent to your team</div>
              <div style="font:500 12px 'Sora',system-ui;color:#3f9a63">Megan and production have your sign-off.</div>
            </div>
          </div>
        </div>

        <!-- FOOTER -->
        <div class="c-section" style="padding-top:30px;padding-bottom:44px">
          <div style="width:26px;height:2px;border-radius:2px;background:#F5A623;margin-bottom:14px"></div>
          <p style="margin:0;font:500 17px/1.4 'Sora',system-ui;color:#4b4b4b">&ldquo;Software should bend to you. Not the other way around.&rdquo;</p>
          <div style="display:flex;align-items:center;gap:9px;margin-top:20px;padding-top:18px;border-top:1px solid #E5E7EB">
            <div style="width:11px;height:11px;border-radius:3px;background:#F5A623"></div>
            <span style="font:700 11px 'Sora',system-ui;letter-spacing:.18em;color:#1A1A1A">BUCKER LABS</span>
            <span style="font:500 9px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.06em;text-transform:uppercase;color:#b3b8c0;margin-left:auto">No password &middot; No location</span>
          </div>
        </div>

      </div><!-- /companion-main -->

      <!-- ====== RIGHT / CHAT SIDEBAR ====== -->
      <div class="companion-sidebar">
        <div class="companion-sidebar-pad" style="animation:scRise .8s ease both">
          <div class="chat-panel">

            <div class="chat-header-bar">
              <div style="position:relative;width:34px;height:34px;border-radius:50%;background:#F5A623;color:#1A1A2E;display:flex;align-items:center;justify-content:center;font:700 12px 'Sora',system-ui;flex:none">
                <%= org_initials %>
                <span style="position:absolute;right:-1px;bottom:-1px;width:10px;height:10px;border-radius:50%;background:#22a06b;border:2px solid #fff"></span>
              </div>
              <div style="line-height:1.25">
                <div style="font:600 14px 'Sora',system-ui;color:#1A1A1A">Your companion</div>
                <div style="font:500 9.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.1em;text-transform:uppercase;color:#9aa0ac">Answers any time of day</div>
              </div>
            </div>

            <div class="chat-messages" data-companion-target="messageArea">
              <% @messages.each do |msg| %>
                <%= render partial: "home/message", locals: { msg: msg } %>
              <% end %>

              <div data-companion-target="chips" style="display:flex;flex-wrap:wrap;gap:8px;margin-top:6px">
                <% ["What did I pick for the kitchen?", "Tell me about Charlotte's room", "When's my next milestone?", "Can I still change my counters?"].each do |chip| %>
                  <button data-action="click->companion#sendChip" data-chip-text="<%= chip %>"
                    style="display:inline-flex;align-items:center;gap:6px;padding:8px 13px;border:1px solid rgba(245,166,35,.35);border-radius:999px;background:rgba(245,166,35,.08);color:#b9791a;font:600 12px 'Sora',system-ui;cursor:pointer;transition:background .15s,color .15s"
                    onmouseover="this.style.background='#F5A623';this.style.color='#0A0C10'" onmouseout="this.style.background='rgba(245,166,35,.08)';this.style.color='#b9791a'">
                    <%= chip %>
                  </button>
                <% end %>
              </div>
            </div>

            <div class="chat-composer">
              <input data-companion-target="composer"
                data-action="keydown->companion#composerKeydown"
                placeholder="Ask about your home&hellip;"
                style="flex:1;padding:12px 16px;border:1px solid #E5E7EB;border-radius:999px;background:#F1F3F8;font:400 15px 'Sora',system-ui;color:#1A1A1A;outline:none;transition:border-color .15s,background .15s"
                onfocus="this.style.borderColor='#F5A623';this.style.background='#fff'"
                onblur="this.style.borderColor='#E5E7EB';this.style.background='#F1F3F8'" />
              <button data-action="click->companion#send"
                style="width:46px;height:46px;flex:none;border:none;border-radius:50%;background:#F5A623;color:#0A0C10;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;transition:filter .15s"
                onmouseover="this.style.filter='brightness(1.05)'" onmouseout="this.style.filter=''">
                &uarr;
              </button>
            </div>

          </div><!-- /chat-panel -->
        </div><!-- /companion-sidebar-pad -->
      </div><!-- /companion-sidebar -->

    </div><!-- /companion-grid -->

  </div><!-- /companion-card -->
</div><!-- /companion-outer -->
