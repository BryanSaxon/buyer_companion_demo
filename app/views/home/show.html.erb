<% org_name     = @lead.org_name %>
<% org_initials = @lead.org_initials %>

<div class="concierge-outer">
  <div class="concierge-card"
       data-controller="concierge"
       data-concierge-messages-url-value="<%= lead_messages_path(@lead) %>"
       data-concierge-selections-url-value="<%= lead_selections_path(@lead) %>"
       data-concierge-org-name-value="<%= org_name %>">

    <!-- ============ BRAND BAR ============ -->
    <div class="brand-bar">
      <!-- Left: identity -->
      <div style="width:38px;height:38px;border-radius:12px;background:#F5A623;color:#1A1A2E;display:flex;align-items:center;justify-content:center;font:700 14px 'Sora',system-ui;flex:none"><%= org_initials %></div>
      <div style="min-width:0;flex:1">
        <div style="font:600 14px 'Sora',system-ui;color:#1A1A1A;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= org_name %></div>
      </div>

      <!-- Center: desktop segmented nav — Concierge first, My Home second -->
      <nav class="brand-nav">
        <button class="brand-nav-btn active" data-action="click->concierge#showChat" data-concierge-target="chatTab">
          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Aria
        </button>
        <button class="brand-nav-btn" data-action="click->concierge#showHome" data-concierge-target="homeTab">
          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11.2 12 4l9 7.2"/><path d="M5.5 9.6V19h13V9.6"/><path d="M10 19v-5h4v5"/></svg>
          My Home
        </button>
      </nav>

      <!-- Right: reset -->
      <div style="display:flex;align-items:center;flex:none">
        <%= link_to demo_reset_path,
              style: "font:600 11px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.08em;text-transform:uppercase;color:#9aa0ac;text-decoration:none;display:flex;align-items:center;gap:5px;padding:6px 11px;border:1px solid #E5E7EB;border-radius:8px;transition:all .15s",
              onmouseover: "this.style.color='#F5A623';this.style.borderColor='#F5A623'",
              onmouseout: "this.style.color='#9aa0ac';this.style.borderColor='#E5E7EB'" do %>
          ↺ Reset
        <% end %>
      </div>
    </div>

    <!-- ============ MOBILE TAB BAR — Concierge first, My Home second ============ -->
    <div class="mobile-tab-bar">
      <button class="mobile-tab active" data-action="click->concierge#showChat" data-concierge-target="chatTab">
        <div class="mobile-tab__icon">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          <span class="tab-dot" data-concierge-target="tabDot"></span>
        </div>
        Aria
      </button>
      <button class="mobile-tab" data-action="click->concierge#showHome" data-concierge-target="homeTab">
        <div class="mobile-tab__icon">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11.2 12 4l9 7.2"/><path d="M5.5 9.6V19h13V9.6"/><path d="M10 19v-5h4v5"/></svg>
        </div>
        My Home
      </button>
    </div>

    <!-- ============ CONTENT GRID ============ -->
    <div class="concierge-grid chat-active" data-concierge-target="grid">

      <!-- LEFT / MY BUILD -->
      <div class="concierge-main">
        <%= render "home/design_brief", session: @session %>
      </div>

      <!-- RIGHT / CONCIERGE CHAT -->
      <div class="concierge-sidebar">
        <div class="concierge-sidebar-pad" style="animation:scRise .8s ease both">
          <div class="chat-panel">

            <div class="chat-header-bar">
              <div style="position:relative;width:34px;height:34px;border-radius:50%;background:#F5A623;color:#1A1A2E;display:flex;align-items:center;justify-content:center;font:700 12px 'Sora',system-ui;flex:none">
                <%= org_initials %>
                <span style="position:absolute;right:-1px;bottom:-1px;width:10px;height:10px;border-radius:50%;background:#22a06b;border:2px solid #fff"></span>
              </div>
              <div style="line-height:1.25">
                <div style="font:600 14px 'Sora',system-ui;color:#1A1A1A">Aria</div>
                <div style="font:500 9.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.1em;text-transform:uppercase;color:#9aa0ac">Here every step of the way</div>
              </div>
            </div>

            <div class="chat-messages" data-concierge-target="messageArea">
              <% @messages.each do |msg| %>
                <% if msg.role == "user" %>
                  <div style="display:flex;margin:0 0 11px;justify-content:flex-end">
                    <div style="max-width:84%;overflow-wrap:break-word;background:#1A1A2E;color:#fff;padding:11px 15px;border-radius:16px 16px 5px 16px;font:400 14.5px/1.5 'Sora',system-ui">
                      <%= h msg.content %>
                    </div>
                  </div>
                <% elsif msg.content.present? %>
                  <div style="display:flex;margin:0 0 11px;justify-content:flex-start">
                    <div style="max-width:88%;overflow-wrap:break-word;background:#fff;color:#1A1A1A;padding:11px 15px;border-radius:16px 16px 16px 5px;font:400 14.5px/1.52 'Sora',system-ui;border:1px solid #E5E7EB;box-shadow:0 1px 6px rgba(0,0,0,.04)">
                      <%= h msg.content %>
                    </div>
                  </div>
                <% end %>
              <% end %>

              <% if @initial_component_html.present? %>
                <div class="chat-component-wrapper" data-concierge-target="componentWrapper">
                  <%= @initial_component_html.html_safe %>
                </div>
              <% end %>
            </div>

            <div class="chat-composer">
              <input data-concierge-target="composer"
                data-action="keydown->concierge#composerKeydown"
                placeholder="Ask anything…"
                style="flex:1;padding:12px 16px;border:1px solid #E5E7EB;border-radius:999px;background:#F1F3F8;font:400 15px 'Sora',system-ui;color:#1A1A1A;outline:none;transition:border-color .15s,background .15s"
                onfocus="this.style.borderColor='#F5A623';this.style.background='#fff'"
                onblur="this.style.borderColor='#E5E7EB';this.style.background='#F1F3F8'" />
              <button data-action="click->concierge#send"
                style="width:46px;height:46px;flex:none;border:none;border-radius:50%;background:#F5A623;color:#0A0C10;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;transition:filter .15s"
                onmouseover="this.style.filter='brightness(1.05)'" onmouseout="this.style.filter=''">
                &uarr;
              </button>
            </div>

          </div><!-- /chat-panel -->
        </div><!-- /concierge-sidebar-pad -->
      </div><!-- /concierge-sidebar -->

    </div><!-- /concierge-grid -->

  </div><!-- /concierge-card -->
</div><!-- /concierge-outer -->
