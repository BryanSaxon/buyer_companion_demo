<% is_user = msg.role == "user" %>
<div style="display:flex;margin:0 0 11px;<%= is_user ? 'justify-content:flex-end' : 'justify-content:flex-start' %>">
  <div style="<%= is_user ? 'max-width:84%;overflow-wrap:break-word;background:#1A1A2E;color:#fff;padding:11px 15px;border-radius:16px 16px 5px 16px;font:400 14.5px/1.5 Sora,system-ui;' : 'max-width:88%;overflow-wrap:break-word;background:#fff;color:#1A1A1A;padding:11px 15px;border-radius:16px 16px 16px 5px;font:400 14.5px/1.52 Sora,system-ui;border:1px solid #E5E7EB;box-shadow:0 1px 6px rgba(0,0,0,.04);' %>">
    <%= msg.content %>
  </div>
</div>
