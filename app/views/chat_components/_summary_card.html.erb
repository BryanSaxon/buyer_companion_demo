<div class="chat-component chat-component--summary" data-component="summary_card">
  <div style="font:600 12px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.1em;text-transform:uppercase;color:#F5A623;margin-bottom:14px">
    Your Design Selections
  </div>
  <% session.summary_by_room.each do |entry| %>
    <div style="margin-bottom:14px;padding-bottom:14px;border-bottom:1px solid #E5E7EB">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:7px">
        <div style="font:600 13.5px 'Sora',system-ui;color:#1A1A1A"><%= entry[:room][:label] %></div>
        <button style="font:600 11px 'Sora',system-ui;color:#F5A623;background:none;border:none;cursor:pointer;padding:2px 4px"
                data-action="click->companion#editRoom"
                data-room-key="<%= entry[:room][:key] %>">
          Edit
        </button>
      </div>
      <% entry[:selections].each do |sel| %>
        <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;margin-bottom:4px">
          <span style="font:500 10px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.05em;text-transform:uppercase;color:#9aa0ac">
            <%= sel.selection_type.humanize %>
          </span>
          <span style="font:600 12px 'Sora',system-ui;color:<%= sel.pending? ? '#9aa0ac' : '#1A1A1A' %>">
            <%= sel.pending? ? "— decide at meeting" : sel.option_label %>
          </span>
        </div>
      <% end %>
    </div>
  <% end %>
  <div style="display:flex;flex-direction:column;gap:8px;margin-top:4px">
    <button class="chat-component-btn chat-component-btn--primary"
            data-action="click->companion#summaryDone">
      These look great — I'm happy! ✓
    </button>
    <button class="chat-component-btn chat-component-btn--secondary"
            data-action="click->companion#summaryChangeIntent">
      I'd like to change something
    </button>
  </div>
</div>
