<div class="chat-component chat-component--email" data-component="email_draft">
  <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px">
    <div style="width:30px;height:30px;border-radius:8px;background:rgba(245,166,35,.12);display:flex;align-items:center;justify-content:center;flex:none">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#F5A623" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
    </div>
    <div>
      <div style="font:600 12.5px 'Sora',system-ui;color:#1A1A1A">Draft email to <%= DemoData::HOME[:designer] %></div>
      <div style="font:400 11px 'Sora',system-ui;color:#9aa0ac">Ready to copy — not sent</div>
    </div>
  </div>
  <div style="background:#F7F6F2;border-radius:10px;padding:12px 14px;margin-bottom:10px">
    <div style="font:600 10.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.08em;text-transform:uppercase;color:#9aa0ac;margin-bottom:4px">Subject</div>
    <div style="font:500 13px 'Sora',system-ui;color:#1A1A1A;margin-bottom:10px"><%= draft.subject %></div>
    <div style="font:600 10.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.08em;text-transform:uppercase;color:#9aa0ac;margin-bottom:4px">Message</div>
    <div style="font:400 13px/1.55 'Sora',system-ui;color:#3f3f3f;white-space:pre-line"><%= draft.body %></div>
  </div>
  <button class="chat-component-btn chat-component-btn--secondary"
          style="font-size:12px"
          data-action="click->concierge#copyEmail"
          data-email-id="<%= draft.id %>"
          data-copy-text="<%= CGI.escapeHTML("Subject: #{draft.subject}\n\n#{draft.body}") %>">
    Copy to clipboard
  </button>
</div>
