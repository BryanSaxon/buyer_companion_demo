<% room_config = DemoData.room(room_key) %>
<% sels = session.design_selections.where(room_key: room_key).order(:created_at) %>
<div class="chat-component chat-component--progress" data-component="progress_card">
  <div style="display:flex;align-items:center;gap:9px;margin-bottom:10px">
    <div style="width:22px;height:22px;border-radius:50%;background:#22a06b;color:#fff;display:flex;align-items:center;justify-content:center;font-size:12px;flex:none">✓</div>
    <div style="font:600 13.5px 'Sora',system-ui;color:#15803d"><%= room_config[:label] %> complete</div>
  </div>
  <div style="display:flex;flex-direction:column;gap:4px;margin-bottom:12px">
    <% sels.each do |sel| %>
      <div style="display:flex;justify-content:space-between;align-items:center;gap:8px">
        <span style="font:500 10.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.05em;text-transform:uppercase;color:#9aa0ac">
          <%= sel.selection_type.humanize %>
        </span>
        <span style="font:600 12.5px 'Sora',system-ui;color:<%= sel.pending? ? '#9aa0ac' : '#1A1A1A' %>">
          <%= sel.pending? ? "Not sure yet" : sel.option_label %>
        </span>
      </div>
    <% end %>
  </div>
  <div style="display:flex;align-items:center;gap:7px;padding-top:10px;border-top:1px solid #E5E7EB;margin-bottom:10px">
    <div style="font:400 11.5px 'Sora',system-ui;color:#9aa0ac"><%= rooms_complete %> of 8 rooms complete</div>
    <div style="flex:1;height:4px;background:#E5E7EB;border-radius:2px;overflow:hidden">
      <div style="height:100%;width:<%= (rooms_complete.to_f / 8 * 100).round %>%;background:#F5A623;border-radius:2px"></div>
    </div>
  </div>
  <button class="chat-component-btn chat-component-btn--primary"
          data-action="click->companion#progressNext">
    Next room →
  </button>
</div>
