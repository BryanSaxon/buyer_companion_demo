<% room_config       = DemoData.room(room_key) %>
<% room_display_label = local_assigns.fetch(:room_display_label, room_config[:label]) %>
<% sels = session.design_selections.where(room_key: room_key).order(:created_at) %>
<% pct = (rooms_complete.to_f / 8 * 100).round %>
<% design_render = session.design_renders.find_by(room_key: room_key) %>
<div class="chat-component chat-component--wide" data-component="progress_card"
     style="background:linear-gradient(135deg,#f0fdf4 0%,#dcfce7 100%);border-color:#86efac;padding:18px 18px 16px">

  <!-- Room complete header -->
  <div style="display:flex;align-items:center;gap:11px;margin-bottom:14px;padding-bottom:14px;border-bottom:1px solid #bbf7d0">
    <div style="width:32px;height:32px;border-radius:50%;background:#22a06b;color:#fff;display:flex;align-items:center;justify-content:center;font-size:16px;flex:none;box-shadow:0 2px 8px rgba(34,160,107,.35)">✓</div>
    <div style="flex:1;min-width:0">
      <div style="font:700 15px/1.2 'Sora',system-ui;color:#15803d"><%= room_display_label %> complete!</div>
      <div style="font:500 10px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.09em;text-transform:uppercase;color:#4ade80;margin-top:2px">All selections locked in</div>
    </div>
  </div>

  <!-- Selections recap -->
  <div style="display:flex;flex-direction:column;gap:5px;margin-bottom:14px">
    <% sels.each do |sel| %>
      <div style="display:flex;justify-content:space-between;align-items:center;gap:8px">
        <span style="font:500 9.5px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.06em;text-transform:uppercase;color:#6b7280">
          <%= sel.selection_type.humanize %>
        </span>
        <span style="font:600 12.5px 'Sora',system-ui;color:<%= sel.pending? ? '#9aa0ac' : '#15803d' %>">
          <%= sel.pending? ? "Deciding later" : sel.option_label %>
        </span>
      </div>
    <% end %>
  </div>

  <!-- AI room rendering preview -->
  <% if design_render %>
    <div id="room-render-<%= room_key %>"
         style="margin-bottom:14px;border-radius:10px;overflow:hidden"
         data-render-status="<%= design_render.status %>">
      <% if design_render.status == "complete" && design_render.image.attached? %>
        <div style="font:500 9px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.09em;text-transform:uppercase;color:#4ade80;margin-bottom:6px">✦ AI Room Rendering</div>
        <%= image_tag url_for(design_render.image),
              style: "width:100%;display:block;border-radius:10px;box-shadow:0 4px 16px rgba(0,0,0,.12)",
              alt: "#{room_config[:label]} rendering" %>
      <% elsif design_render.status == "deferred" %>
        <div style="border-radius:10px;background:#F5F4EF;border:1.5px dashed #D1D5DB;padding:18px 16px;display:flex;align-items:flex-start;gap:12px">
          <div style="width:32px;height:32px;border-radius:50%;background:#E8E0D0;display:flex;align-items:center;justify-content:center;flex:none;font-size:15px">🎨</div>
          <div>
            <div style="font:600 11.5px 'Sora',system-ui;color:#1A1A1A;margin-bottom:4px">Room preview on hold</div>
            <div style="font:400 11.5px/1.55 'Sora',system-ui;color:#6b7280">Your AI rendering will generate automatically once you've chosen a design style. Head back to your Concierge and pick a style — all your room previews will appear at once.</div>
          </div>
        </div>
      <% else %>
        <div style="height:150px;border-radius:10px;background:linear-gradient(90deg,rgba(34,160,107,.08) 25%,rgba(34,160,107,.16) 50%,rgba(34,160,107,.08) 75%);background-size:200% 100%;animation:shimmer 1.8s ease-in-out infinite;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;border:1.5px dashed #86efac">
          <div style="font:600 11px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.09em;text-transform:uppercase;color:#4ade80">✦ AI Rendering</div>
          <div style="font:500 11.5px 'Sora',system-ui;color:#6b7280">Generating your room…</div>
        </div>
        <script>
          (function() {
            var leadId = '<%= session.lead_id %>';
            var roomKey = '<%= room_key %>';
            var elId = 'room-render-' + roomKey;
            var btnId = 'next-room-btn-' + roomKey;
            var poll = setInterval(async function() {
              try {
                var r = await fetch('/leads/' + leadId + '/rooms/' + roomKey + '/render');
                var d = await r.json();
                var el = document.getElementById(elId);
                if (!el) { clearInterval(poll); return; }
                if (d.status === 'complete') {
                  clearInterval(poll);
                  var label = document.createElement('div');
                  label.setAttribute('style', 'font:500 9px \'IBM Plex Mono\',ui-monospace,monospace;letter-spacing:.09em;text-transform:uppercase;color:#4ade80;margin-bottom:6px');
                  label.textContent = '❆ AI Room Rendering';
                  var img = new Image();
                  img.setAttribute('style', 'width:100%;display:block;border-radius:10px;box-shadow:0 4px 16px rgba(0,0,0,.12)');
                  img.onload = function() {
                    el.innerHTML = '';
                    el.appendChild(label);
                    el.appendChild(img);
                    el.dataset.renderStatus = 'complete';
                    var btn = document.getElementById(btnId);
                    if (btn) btn.style.display = 'block';
                  };
                  img.onerror = function() {
                    el.style.display = 'none';
                    var btn = document.getElementById(btnId);
                    if (btn) btn.style.display = 'block';
                  };
                  img.src = d.image_url;
                } else if (d.status === 'failed') {
                  clearInterval(poll);
                  el.style.display = 'none';
                  var btn = document.getElementById(btnId);
                  if (btn) btn.style.display = 'block';
                }
              } catch(e) {}
            }, 3000);
          })();
        </script>
      <% end %>
    </div>
  <% end %>

  <!-- Progress bar -->
  <div style="display:flex;align-items:center;gap:9px;padding:11px 0;border-top:1px solid #bbf7d0;border-bottom:1px solid #bbf7d0;margin-bottom:12px">
    <div style="font:700 13px 'Sora',system-ui;color:#15803d;white-space:nowrap"><%= rooms_complete %> of 8</div>
    <div style="flex:1;height:5px;background:rgba(0,0,0,.08);border-radius:3px;overflow:hidden">
      <div style="height:100%;width:<%= pct %>%;background:#22a06b;border-radius:3px;transition:width .6s ease"></div>
    </div>
    <div style="font:500 10px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.07em;text-transform:uppercase;color:#4ade80;white-space:nowrap">rooms done</div>
  </div>

  <% rendering_in_progress = design_render && %w[pending generating].include?(design_render.status) %>
  <button id="next-room-btn-<%= room_key %>"
          class="chat-component-btn chat-component-btn--primary"
          style="background:#22a06b;color:#fff;<%= 'display:none' if rendering_in_progress %>"
          data-action="click->concierge#progressNext">
    <%= rooms_complete >= 8 ? "Review my selections →" : "Ready for the next room →" %>
  </button>
</div>
