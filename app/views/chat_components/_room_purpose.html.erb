<% locked           = local_assigns.fetch(:locked, false) %>
<% selected_purpose = local_assigns.fetch(:selected_purpose, nil) %>
<% hide_bedroom     = local_assigns.fetch(:hide_bedroom, false) %>
<% purposes = hide_bedroom ? DemoData::FLEX_PURPOSES.reject { |p| p[:key] == "bedroom" } : DemoData::FLEX_PURPOSES %>
<div class="chat-component" data-component="room_purpose" data-room-key="<%= room[:key] %>">
  <div style="margin-bottom:10px;font:600 11px 'IBM Plex Mono',ui-monospace,monospace;letter-spacing:.1em;text-transform:uppercase;color:<%= locked ? '#22a06b' : '#9aa0ac' %>">
    <%= locked ? "✓ Locked in" : "Select a purpose" %>
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
    <% purposes.each do |p| %>
      <% is_selected = locked && selected_purpose.to_s == p[:key].to_s %>
      <button class="chat-component-btn chat-component-btn--option purpose-btn<%= ' chat-component-btn--selected' if is_selected %>"
              <%= "disabled" if locked %>
              style="<%= locked ? "cursor:default;pointer-events:none;#{'opacity:0.35' unless is_selected}" : "" %>"
              data-action="<%= locked ? '' : 'click->concierge#selectPurpose' %>"
              data-room-key="<%= room[:key] %>"
              data-purpose-key="<%= p[:key] %>">
        <%= p[:label] %>
        <% if is_selected %> ✓<% end %>
      </button>
    <% end %>
  </div>
  <% unless locked %>
    <div id="purpose-other-input" style="display:none;margin-top:10px;gap:8px;flex-direction:column">
      <input type="text" placeholder="Describe the purpose…"
             style="width:100%;padding:10px 13px;border:1px solid #E5E7EB;border-radius:10px;font:400 14px 'Sora',system-ui;background:#fff;outline:none"
             onfocus="this.style.borderColor='#F5A623'" onblur="this.style.borderColor='#E5E7EB'"
             data-purpose-other-input>
      <button class="chat-component-btn chat-component-btn--primary"
              data-action="click->concierge#confirmPurposeOther"
              data-room-key="<%= room[:key] %>">
        Confirm
      </button>
    </div>
  <% end %>
</div>
